# =================================================================
# Identification of Invariant References and moving components
# Methodology: VLR (Log-Ratio Variance) + CV Asymmetry Analysis
# Features: Red Marker, Viridis Heatmap, Explicit Sample Extraction
# Engine: Pure Base R (No External Libraries)
# =================================================================

# --- 1. User Configuration & Data Cleaning ---
# Dataset: Rows = Samples, Columns = Taxa. 
# Must contain only numeric abundance data.
ds_input <- as.matrix(Dataset)
min_abundance_threshold <- 0.00001  
fixed_vlr_threshold <- 0.05      

# Strict Filtering
valid_taxa_mask <- apply(ds_input, 2, function(x) !any(is.na(x)) && min(x, na.rm = TRUE) >= min_abundance_threshold)
data <- ds_input[, valid_taxa_mask]
n_samples <- nrow(data); n_taxa <- ncol(data)
taxa_names <- colnames(data); sample_names <- rownames(data)
log_data <- log(data)

cat(sprintf("--- Filtering Summary ---\nOriginal Taxa: %d | Retained Taxa: %d\nThreshold: %g\n", 
            ncol(ds_input), n_taxa, min_abundance_threshold))

# --- 2. Invariant Reference Identification (VLR & CV) ---
cov_mat <- var(log_data); diag_vec <- diag(cov_mat)
vlr_mat <- outer(diag_vec, diag_vec, "+") - 2 * cov_mat
var_sum_mat <- outer(diag_vec, diag_vec, "+")

win_counts <- numeric(n_taxa)
for (j in 1:n_taxa) {
  cv_j <- apply(data / data[, j], 2, function(x) sd(x) / mean(x))
  cv_inv <- apply(sweep(1/data, 1, data[, j], "*"), 2, function(x) sd(x) / mean(x))
  win_counts[j] <- sum(cv_j < cv_inv, na.rm = TRUE)
}

# --- 3. Reference Candidate Scoring ---
vlr_flat <- vlr_mat; diag(vlr_flat) <- NA
stable_pair_idx <- which(vlr_flat <= quantile(vlr_flat, 10/(n_taxa^2-n_taxa), na.rm=T), arr.ind=T)
stable_taxa_pool <- unique(taxa_names[stable_pair_idx])

combined_res <- data.frame(
  Taxa = taxa_names, VLR_Value = diag_vec, VLR_Rank = rank(diag_vec),
  Win_Count = as.numeric(win_counts), CV_Rank = rank(-win_counts),
  Total_Score = rank(diag_vec) + rank(-win_counts),
  In_Stable_Pair = taxa_names %in% stable_taxa_pool
)
combined_res <- combined_res[order(combined_res$Total_Score), ]

# --- 4. Co-movement & Exclusion Analytics ---
rho_mat <- 1 - (vlr_mat / var_sum_mat); neg_score_mat <- vlr_mat / var_sum_mat
vlr_dynamic_cutoff <- quantile(vlr_mat[lower.tri(vlr_mat)], 0.01)

# --- 5. Executing Robustness Analysis ---
best_match <- combined_res[combined_res$In_Stable_Pair == TRUE, ]
ref_taxon_name <- if(nrow(best_match) > 0) as.character(best_match$Taxa[1]) else as.character(combined_res$Taxa[1])

cat(sprintf("\n=== Executing Robustness Analysis (Reference Denominator: %s) ===\n", ref_taxon_name))

target_taxa <- taxa_names[taxa_names != ref_taxon_name]; n_targets <- length(target_taxa)
trend_median <- matrix(NA, n_targets, n_samples)
trend_sd     <- matrix(NA, n_targets, n_samples)
rownames(trend_median) <- rownames(trend_sd) <- target_taxa

for (i in 1:n_targets) {
  alr_vec <- log(data[, target_taxa[i]] / data[, ref_taxon_name])
  diff_mat <- outer(alr_vec, alr_vec, "-")
  trend_median[i, ] <- apply(diff_mat, 1, median)
  trend_sd[i, ]     <- apply(diff_mat, 1, sd)
}
confidence_score <- abs(trend_median) / (trend_sd + 0.01)

# --- Extraction of Max Point ---
m_val <- max(confidence_score)
m_loc <- which(confidence_score == m_val, arr.ind = TRUE)[1, ]
m_taxon_name <- rownames(confidence_score)[m_loc[1]]
m_sample_idx <- as.numeric(m_loc[2])
m_sample_name <- sample_names[m_sample_idx]

# =================================================================
# FULL ANALYTICAL REPORT (NO OMISSION)
# =================================================================
cat("\n=== [INVARIANT REFERENCE CANDIDATES (Top 10)] ===\n")
print(head(combined_res, 10))

cat(sprintf("\n=== Co-moving Taxa Pairs (Fixed Threshold: VLR <= %.4f) ===\n", fixed_vlr_threshold))
f_idx <- which(vlr_mat <= fixed_vlr_threshold & lower.tri(vlr_mat), arr.ind = TRUE)
if(nrow(f_idx) > 0) print(data.frame(Taxon_A=taxa_names[f_idx[,1]], Taxon_B=taxa_names[f_idx[,2]], VLR=vlr_mat[f_idx]))

cat(sprintf("\n=== Co-moving Taxa Pairs (Dynamic Threshold: Bottom 1%%, VLR <= %.4f) ===\n", vlr_dynamic_cutoff))
s_idx <- which(vlr_mat <= vlr_dynamic_cutoff & lower.tri(vlr_mat), arr.ind = TRUE)
if(nrow(s_idx) > 0) print(data.frame(Taxon_A=taxa_names[s_idx[,1]], Taxon_B=taxa_names[s_idx[,2]], VLR=vlr_mat[s_idx], Rho_p=rho_mat[s_idx]))

cat("\n=== Potential Negative Correlation Pairs (Top 10) ===\n")
neg_idx <- which(neg_score_mat > 1.0 & lower.tri(neg_score_mat), arr.ind = TRUE)
if(nrow(neg_idx) > 0) {
  neg_list <- data.frame(Taxon_A=taxa_names[neg_idx[,1]], Taxon_B=taxa_names[neg_idx[,2]], VLR=vlr_mat[neg_idx], Exp_Var_Sum=var_sum_mat[neg_idx], Neg_Score=neg_score_mat[neg_idx])
  print(head(neg_list[order(neg_list$Neg_Score, decreasing=T), ], 10))
  
  cat("\n=== Filtered Negative Correlation Pairs (Excluding low-variance noise) ===\n")
  neg_list_filtered <- neg_list[neg_list$Exp_Var_Sum > quantile(diag_vec, 0.25), ]
  print(head(neg_list_filtered[neg_list_filtered$Neg_Score > 1.0, ], 10))
}

significant_hits <- which(confidence_score > 5, arr.ind = TRUE)
if(nrow(significant_hits) > 0) {
  cat("\n=== Statistically Highly Robust Variations (Score > 5) === \n")
  res_summary <- data.frame(Taxon = rownames(confidence_score)[significant_hits[,1]], Sample = sample_names[significant_hits[,2]], Score = confidence_score[significant_hits])
  print(res_summary[order(res_summary$Score, decreasing = TRUE), ])
} else {
  cat("\nNo highly robust variations exceeding a score of 5 were found.\n")
}

# --- MANDATORY CONCLUSION (FIXED OUTPUT) ---
cat("\n=== Final Conclusion (Robustness Analysis) ===\n")
cat(paste0("Adopted Invariant Reference: ", ref_taxon_name, "\n"))
cat(paste0("Taxon with most certain fluctuation (vs Ref): ", m_taxon_name, "\n"))
cat(paste0("Sample with maximum confidence: ", m_sample_name, " (Index: ", m_sample_idx, ")\n"))

