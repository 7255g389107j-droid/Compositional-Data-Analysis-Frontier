# =================================================================
viridis_pal <- colorRampPalette(c("#440154", "#3b528b", "#21908c", "#5dc963", "#fde725"))(100)

# [WINDOW 1] DIAGNOSTICS
dev.new(width=12, height=5); par(mfrow = c(1, 3))
hist(vlr_mat[lower.tri(vlr_mat)], 40, col="skyblue", main="VLR Dist"); hist(neg_score_mat[lower.tri(neg_score_mat)], 40, col="salmon", main="Exclusion"); abline(v=1, col="red", lty=2); hist(confidence_score, 40, col="#5dc963", main="Robustness")

# [WINDOW 2] SCATTER
dev.new(width=10, height=5); par(mfrow = c(1, 2))
lp <- which(vlr_flat == min(vlr_flat, na.rm=T), arr.ind=T)[1,]; plot(log_data[,lp[1]], log_data[,lp[2]], pch=19, col="#3498db", main="Min VLR", xlab=taxa_names[lp[1]], ylab=taxa_names[lp[2]]); abline(lm(log_data[,lp[2]] ~ log_data[,lp[1]]), col="#e74c3c", lwd=2)
hp <- which(neg_score_mat == max(neg_score_mat[lower.tri(neg_score_mat)], na.rm=T), arr.ind=T)[1,]; plot(log_data[,hp[1]], log_data[,hp[2]], pch=19, col="#e74c3c", main="Max Exclusion", xlab=taxa_names[hp[1]], ylab=taxa_names[hp[2]]); abline(lm(log_data[,hp[2]] ~ log_data[,hp[1]]), col="#3498db", lwd=2, lty=2)

# [WINDOW 3] NATURE HEATMAP (VIRIDIS + RED MARKER)
dev.new(width=12, height=7); layout(matrix(1:2, 1, 2), widths=c(0.85, 0.15)); par(mar = c(7, 12, 5, 1))
top_h <- rownames(confidence_score)[order(apply(confidence_score, 1, max), decreasing=T)[1:min(10, n_targets)]]
plot_h <- confidence_score[top_h, , drop=FALSE]
image(1:n_samples, 1:nrow(plot_h), t(log1p(plot_h)), col=viridis_pal, axes=F, main=paste("Robustness Heatmap | Ref:", ref_taxon_name))
axis(1, at=1:n_samples, labels=sample_names, las=2, cex.axis=0.8); axis(2, at=1:nrow(plot_h), labels=rownames(plot_h), las=1, cex.axis=0.8)
# RED MARKER
m_row_match <- match(m_taxon_name, rownames(plot_h))
if(!is.na(m_row_match)) points(m_sample_idx, m_row_match, pch=4, col="red", lwd=3, cex=2)
par(mar = c(7, 1, 5, 4)); zs <- seq(0, max(log1p(plot_h)), length.out=100); image(1, zs, matrix(zs, 1), col=viridis_pal, axes=F); axis(4, las=1); mtext("log(Score+1)", 4, 2.5, cex=0.7)

# [WINDOW 4] ROBUST TRENDS
dev.new(width=12, height=9); par(mfrow=c(3,2), mar=c(4,5,5,2))
for(i in 1:min(6, length(top_h))) {
  tn <- top_h[i]; y_med <- trend_median[tn, ]; y_sd <- trend_sd[tn, ]
  plot(y_med, type="n", ylim=range(c(y_med+y_sd, y_med-y_sd, 0)), main=paste("Target:", tn, "\nRef Denom:", ref_taxon_name), xlab="Sample", ylab="Shift")
  polygon(c(1:n_samples, n_samples:1), c(y_med+y_sd, rev(y_med-y_sd)), col=rgb(0.2, 0.4, 0.8, 0.15), border=NA)
  abline(h=0, lty=2, col="red"); lines(y_med, type="b", pch=19, col="#2c3e50", lwd=2)
}

# --- 6. Bootstrap Stability (Text-Only Report) ---
n_boot <- 1000
boot_refs <- character(n_boot)

for(b in 1:n_boot) {
  idx <- sample(1:n_samples, replace = TRUE)
  ds_b <- data[idx, ]
  # Pure VLR focus for internal stability check
  diag_b <- apply(log(ds_b), 2, var)
  boot_refs[b] <- taxa_names[which.min(diag_b)]
}

# Calculate selection frequency as percentage
ref_stability_tbl <- table(boot_refs) / n_boot * 100
ref_stability_sorted <- sort(ref_stability_tbl, decreasing = TRUE)

# 1. ACTUAL Adopted Reference Metrics
actual_ref_pct <- if(ref_taxon_name %in% names(ref_stability_tbl)) {
  as.numeric(ref_stability_tbl[ref_taxon_name])
} else {
  0
}

# 2. STATISTICAL Mode (Most Stable Taxon by Bootstrap)
top_ref_name <- names(ref_stability_sorted)[1]
top_ref_pct  <- as.numeric(ref_stability_sorted[1])

# --- Final Reliability Analysis Report ---
cat("\n==========================================\n")
cat("       RELIABILITY ANALYSIS REPORT        \n")
cat("==========================================\n")
cat(sprintf("Most Stable Taxon (Mode): %s\n", top_ref_name))
cat(sprintf("Selection Probability   : %.1f%%\n", top_ref_pct))
cat("------------------------------------------\n")
cat("Top Stability Candidates (Bootstrap):\n")
print(head(ref_stability_sorted, 3))
cat("==========================================\n")

# --- Final Conclusion (Robustness Analysis) ---
cat("\n=== Final Conclusion (Robustness Analysis) ===\n")
cat(paste0("Adopted Invariant Reference: ", ref_taxon_name, " (Bootstrap Support: ", actual_ref_pct, "%)\n"))
cat(paste0("Taxon with most certain fluctuation (vs Ref): ", m_taxon_name, "\n"))
cat(paste0("Sample with maximum confidence: ", m_sample_name, " (Index: ", m_sample_idx, ")\n"))

# --- CRITICAL WARNINGS ---
# Warning 1: Selection Mismatch (Adopted vs Bootstrap Mode)
if(ref_taxon_name != top_ref_name) {
  cat(sprintf("\n[CRITICAL WARNING] REFERENCE MISMATCH!\n"))
  cat(sprintf("Adopted [%s] differs from the Bootstrap Mode [%s].\n", ref_taxon_name, top_ref_name))
  cat("This suggests the choice of reference is sensitive to specific samples.\n")
}

# Warning 2: Low Stability
if(actual_ref_pct < 50) {
  cat("\n[NOTICE] The adopted reference has low bootstrap stability (<50%).\n")
  cat("Interpret fluctuations with caution due to potential Compositional Bias.\n")
}

# =================================================================
# 6.1 AUTOMATIC REFERENCE RE-ASSIGNMENT & COMPARATIVE ANALYSIS
# =================================================================

# 1. Capture Bootstrap Results
top_ref_name <- names(ref_stability_sorted)[1]
top_ref_pct  <- as.numeric(ref_stability_sorted[1])
initial_ref_pct <- if(ref_taxon_name %in% names(ref_stability_tbl)) {
  as.numeric(ref_stability_tbl[ref_taxon_name])
} else { 0 }

# 2. DECISION LOGIC: Which reference is scientifically more robust?
# Criteria: If the Bootstrap Mode offers a stability gain of >10%, we switch.
# This ensures we only move if the improvement in reliability is significant.
stability_gain <- top_ref_pct - initial_ref_pct
use_bootstrap_mode <- (stability_gain > 10)

cat("\n==========================================================\n")
cat("          REFERENCE STABILITY COMPARISON REPORT           \n")
cat("==========================================================\n")
cat(sprintf("Initial Selection : %-15s (Stability: %.1f%%)\n", ref_taxon_name, initial_ref_pct))
cat(sprintf("Bootstrap Mode    : %-15s (Stability: %.1f%%)\n", top_ref_name, top_ref_pct))
cat(sprintf("Stability Gain    : %+.1f%%\n", stability_gain))
cat("----------------------------------------------------------\n")

if (use_bootstrap_mode) {
  cat("DECISION: >>> ADOPT BOOTSTRAP MODE <<<\n")
  cat("REASON  : A significant stability gain was detected. The Bootstrap\n")
  cat("          Mode is less sensitive to sample outliers and represents\n")
  cat("          the data more consistently across random sub-samplings.\n")
  
  # --- Re-calculating with the Superior Reference ---
  old_ref_name <- ref_taxon_name
  ref_taxon_name <- top_ref_name
  target_taxa <- taxa_names[taxa_names != ref_taxon_name]
  n_targets   <- length(target_taxa)
  
  new_trend_median <- matrix(NA, n_targets, n_samples)
  new_trend_sd     <- matrix(NA, n_targets, n_samples)
  rownames(new_trend_median) <- rownames(new_trend_sd) <- target_taxa
  
  for (i in 1:n_targets) {
    # Ratio against the NEW reference (Mode)
    alr_vec  <- log(data[, target_taxa[i]] / data[, ref_taxon_name])
    diff_mat <- outer(alr_vec, alr_vec, "-")
    new_trend_median[i, ] <- apply(diff_mat, 1, median)
    new_trend_sd[i, ]     <- apply(diff_mat, 1, sd)
  }
  
  # Update global variables for visualization consistency
  trend_median <- new_trend_median
  trend_sd     <- new_trend_sd
  confidence_score <- abs(trend_median) / (trend_sd + 0.01)
  
  # Re-extract the point of maximum fluctuation
  m_val <- max(confidence_score)
  m_loc <- which(confidence_score == m_val, arr.ind = TRUE)[1, ]
  m_taxon_name  <- rownames(confidence_score)[m_loc[1]]
  m_sample_idx  <- as.numeric(m_loc[2])
  m_sample_name <- sample_names[m_sample_idx]
  
  cat(sprintf("\nSUCCESS: Data recalculated using [%s].\n", ref_taxon_name))
} else {
  cat("DECISION: >>> MAINTAIN INITIAL SELECTION <<<\n")
  cat("REASON  : The initial selection is either the most stable or the\n")
  cat("          gain from switching is marginal (<10%). The multi-metric\n")
  cat("          scoring (VLR + CV) is deemed robust for this dataset.\n")
}
cat("==========================================================\n")

# Final Conclusion for the selected reference
cat(sprintf("\nFINAL CHOICE    : %s\n", ref_taxon_name))
cat(sprintf("STABILITY SCORE : %.1f%%\n", max(initial_ref_pct, top_ref_pct)))
cat(sprintf("TOP FLUCTUANT   : %s (Max Robustness: %.4f)\n", m_taxon_name, m_val))

