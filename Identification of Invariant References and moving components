# =================================================================
# ADVANCED INVARIANT REFERENCE SELECTION: PURITY INDEX (PI)
# Based on Ohta (2011) with enhanced interpretability
# =================================================================

# 1. Purity Index Calculation Logic
# PI measures how "universally stable" a taxon is against ALL other taxa.
# High PI = This taxon maintains a stable ratio with the majority of the community,
#          suggesting it is not part of a specific moving cluster (Co-variation).

n_taxa <- ncol(data)
purity_scores <- numeric(n_taxa)
names(purity_scores) <- taxa_names

# Matrix to store pairwise VLR (Log-Ratio Variance)
vlr_matrix <- var(log_data)
diag_vec <- diag(vlr_matrix)
vlr_dist <- outer(diag_vec, diag_vec, "+") - 2 * vlr_matrix

for (i in 1:n_taxa) {
  # Calculate VLRs of Taxon i against all other taxa
  ratios_vlr <- vlr_dist[i, -i]
  
  # PI Definition: The inverse of the median VLR against the community.
  # We use Median to be robust against outliers (taxa that are actually moving).
  purity_scores[i] <- 1 / (median(ratios_vlr) + 1e-6)
}

# 2. Ranking and Selection with Purity
# Normalize PI for interpretation (0 to 100 scale)
purity_norm <- (purity_scores / max(purity_scores)) * 100

# Merge with previous CV-Asymmetry (Ohta's Win Count)
final_purity_report <- data.frame(
  Taxon = taxa_names,
  Purity_Index = round(purity_norm, 2),
  Ohta_Win_Count = as.numeric(win_counts),
  Self_Variance = round(diag_vec, 4)
)

# Sorting by Purity (Primary) and Ohta's Logic (Secondary)
final_purity_report <- final_purity_report[order(-final_purity_report$Purity_Index), ]

