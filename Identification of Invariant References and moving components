expected_floor <- theo_variance_floor[anchor_idx]

# Invariance Ratio (IR): Actual Variance / Theoretical Floor
# IR < 1 means the anchor is "Ultra-Stable" (more stable than random sampling noise).
invariance_ratio <- actual_var / expected_floor

