# 1. Estimate Theoretical Shot Noise (Poisson Limit)
# For counts, the theoretical minimum variance equals the mean (Var = Mean).
# In log-space, the variance of log(counts) is approximately 1/Mean.

raw_counts <- Dataset[, valid_taxa_mask] # Use original raw counts
