# --- 1. Diagnostic & Classification (Noise vs Biological) ---
# Define Noise Zone (bottom 15%)
noise_cutoff <- quantile(colMeans(data), 0.15)

# Build Diagnostic Matrix
# Purity: Stability against the entire community
# Ohta_Win: Pairwise CV-asymmetry superiority
diagnostic_df <- data.frame(
  Taxon          = taxa_names,
  Mean_Abund     = colMeans(data),
  Stability      = purity_norm, 
  Ohta_Win_Count = as.numeric(win_counts),
  Type           = ifelse(colMeans(data) < noise_cutoff, "NOISE", "BIOLOGICAL")
)

# Composite Selection Score (Sum of Ranks)
diagnostic_df$Selection_Score <- rank(diagnostic_df$Stability) + rank(diagnostic_df$Ohta_Win_Count)
diagnostic_df <- diagnostic_df[order(-diagnostic_df$Selection_Score), ]

# --- 2. Final Decision Logic for Optimal Anchor ---
best_anchor <- diagnostic_df[1, ]
anchor_name <- as.character(best_anchor$Taxon)
anchor_type <- best_anchor$Type

# --- 3. EXECUTION: ALR Transformation & Robustness Calculation ---
target_taxa <- taxa_names[taxa_names != anchor_name]
alr_matrix  <- log(data[, target_taxa] / data[, anchor_name])

# Robustness Score (Signal-to-Noise Ratio)
# Calculated as: |Median Shift| / (Standard Deviation + epsilon)
shift_median  <- apply(alr_matrix, 2, function(x) median(x - median(x)))
shift_sd      <- apply(alr_matrix, 2, sd)
robust_scores <- abs(shift_median) / (shift_sd + 0.01)

final_results <- data.frame(
  Taxon            = target_taxa,
  Robustness_Score = round(robust_scores, 4),
  Median_Shift     = round(shift_median, 4),
  Dispersion_SD    = round(shift_sd, 4),
  Mean_Abundance   = round(colMeans(data[, target_taxa]), 6)
)
final_results <- final_results[order(-final_results$Robustness_Score), ]

